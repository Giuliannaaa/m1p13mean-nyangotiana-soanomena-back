# Variables d'environnement - Copier ce fichier en .env et remplir les valeurs

# ============================================================
# SERVER
# ============================================================
NODE_ENV=production
PORT=5000

# ============================================================
# DATABASE - MongoDB Atlas (OBLIGATOIRE pour Vercel)
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
# ============================================================
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/supermarket?retryWrites=true&w=majority

# ============================================================
# JWT
# ============================================================
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET
JWT_EXPIRE=1d
JWT_COOKIE_EXPIRE=30

# ============================================================
# CORS - URL du frontend (Angular déployé sur Vercel)
# ============================================================
FRONTEND_URL=https://supermarket-simulation.vercel.app

# ============================================================
# EMAIL (Nodemailer / Mailtrap)
# ============================================================
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=YOUR_MAILTRAP_USER
SMTP_PASSWORD=YOUR_MAILTRAP_PASSWORD
FROM_NAME=Supermarket Soa-Nya
FROM_EMAIL=noreply@supermarket.com

# ============================================================
# FILE UPLOAD (optionnel)
# NOTE: Les uploads locaux ne persistent pas sur Vercel.
# Migrer vers Cloudinary ou AWS S3 pour la production.
# ============================================================
MAX_FILE_UPLOAD=1000000
FILE_UPLOAD_PATH=./public/uploads